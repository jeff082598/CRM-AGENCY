{
  "name": "agency-crm-cloud",
  "version": "1.0.0",
  "description": "Online, shared CRM/Project Management/Billing system for service-based creative agencies — cloud edition (PostgreSQL).",
  "main": "server/app.js",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev:server": "nodemon server/app.js",
    "dev:client": "npm --prefix client run dev",
    "dev": "concurrently -n SERVER,CLIENT -c green,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "npm --prefix client run build",
    "start": "node server/app.js",
    "postinstall": "npm --prefix client install"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "pg": "^8.12.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
